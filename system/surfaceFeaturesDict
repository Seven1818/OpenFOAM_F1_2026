FoamFile
{
    format      ascii;
    class       dictionary;
    object      surfaceFeaturesDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

surfaces (
    "F1_car_m_half.stl"
    "F1_FW_m_half.stl"
    "F1_RW_m_half.stl"
    "F1_FWHL_m_half.stl"
    "F1_RWHL_m_half.stl"
    );


// Identify a feature when angle between faces < includedAngle
includedAngle       45;

subsetFeatures
{
    // Keep nonManifold edges (edges with >2 connected faces)
    nonManifoldEdges       yes;

    // Keep open edges (edges with 1 connected face)
    openEdges       yes;
}

